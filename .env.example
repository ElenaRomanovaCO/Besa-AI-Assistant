# =============================================================================
# BeSa AI Assistant — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before deployment.
#
# Values marked REPLACE_ME must be filled in before deployment.
# Values marked (CDK Output) are emitted by `cdk deploy` and copied afterwards.
# =============================================================================


# =============================================================================
# FRONTEND (Next.js) — create frontend/.env.local with these values
# =============================================================================

# Cognito User Pool — from CDK Output: AdminStack.UserPoolId
NEXT_PUBLIC_COGNITO_USER_POOL_ID=REPLACE_ME

# Cognito App Client — from CDK Output: AdminStack.UserPoolClientId
NEXT_PUBLIC_COGNITO_CLIENT_ID=REPLACE_ME

# Admin API Gateway base URL — from CDK Output: AdminStack.AdminAPIUrl
# Include trailing slash if present in the CDK output
NEXT_PUBLIC_API_URL=REPLACE_ME


# =============================================================================
# DISCORD BOT — set before running `cdk deploy`
# See: docs/DISCORD_SETUP.md for how to obtain these values
# =============================================================================

# From Discord Developer Portal → Your App → General Information
DISCORD_APPLICATION_ID=REPLACE_ME

# Your Discord server (guild) ID — enable Developer Mode in Discord, right-click server
DISCORD_GUILD_ID=REPLACE_ME

# The #besa-ai-assistant channel ID — right-click the channel in Discord
DISCORD_BOT_CHANNEL_ID=REPLACE_ME


# =============================================================================
# SECRETS MANAGER — stored as secrets, NOT Lambda env vars
# Upload these after deployment via AWS Console or CLI (see docs/DISCORD_SETUP.md)
# =============================================================================

# Discord Bot Token — Developer Portal → Your App → Bot → Reset Token
# Store in: Secrets Manager → besa-ai-assistant/discord/bot-token
# DISCORD_BOT_TOKEN=REPLACE_ME   # <-- DO NOT put in .env files; use Secrets Manager

# Discord Public Key — Developer Portal → Your App → General Information
# Store in: Secrets Manager → besa-ai-assistant/discord/public-key
# DISCORD_PUBLIC_KEY=REPLACE_ME  # <-- DO NOT put in .env files; use Secrets Manager


# =============================================================================
# LOCAL DEVELOPMENT (backend) — used when running tests or local dev server
# =============================================================================

AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=testing
AWS_SECRET_ACCESS_KEY=testing

# DynamoDB table names (match CDK stack outputs)
CONFIG_TABLE_NAME=besa-ai-assistant-config
LOGS_TABLE_NAME=besa-ai-assistant-logs
RATE_LIMIT_TABLE_NAME=besa-ai-assistant-rate-limits
STATE_TABLE_NAME=besa-ai-assistant-state

# S3 bucket for FAQ files — from CDK Output: StorageStack.FAQBucketName
FAQ_BUCKET_NAME=REPLACE_ME

# Bedrock Knowledge Base — from CDK Output: StorageStack.KnowledgeBaseId
BEDROCK_KNOWLEDGE_BASE_ID=REPLACE_ME

# Bedrock Data Source — from CDK Output: StorageStack.DataSourceId
BEDROCK_DATA_SOURCE_ID=REPLACE_ME

# SQS queue URL — from CDK Output: AgentStack.ProcessingQueueUrl
PROCESSING_QUEUE_URL=REPLACE_ME

# Secrets Manager ARNs — from CDK Outputs
DISCORD_BOT_TOKEN_SECRET_ARN=REPLACE_ME
DISCORD_PUBLIC_KEY_SECRET_ARN=REPLACE_ME
