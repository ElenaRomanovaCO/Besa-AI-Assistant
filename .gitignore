# =============================================================================
# BeSa AI Assistant — .gitignore
# =============================================================================

# Lambda layer build output (regenerated by build_layer.sh)
backend/layer/python/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# Virtual environments
.venv/
venv/
env/
.env
.venv/

# Environment variable files (contain secrets)
.env.local
.env.*.local
frontend/.env.local
frontend/.env.production

# Test & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Type checking
.mypy_cache/
.dmypy.json

# CDK
infrastructure/cdk.out/
infrastructure/.cdk.staging/

# Node / Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Secrets (never commit these)
*.pem
*.key
*.crt
secrets.json
credentials.json
